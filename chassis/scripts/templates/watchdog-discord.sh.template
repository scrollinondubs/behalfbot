#!/bin/bash
# Prepend brew prefix so tmux is found under launchd, which inherits a minimal
# PATH. On Linux the brew dir does not exist and this prefix is a harmless no-op.
export PATH="/opt/homebrew/bin:$PATH"

# Wait up to 90s for Docker daemon to be available (Colima VM boot on cold
# start). The watchdog itself doesn't docker-exec, but its restart-script
# child does. Waiting here ensures the recovery path lands on a live docker
# socket rather than tearing down + recreating a tmux session that would
# fail-loop until Colima catches up. Linux installs no-op on iteration 1.
# See chassis#16.
for i in {1..30}; do
    if docker info >/dev/null 2>&1; then break; fi
    sleep 3
done

# watchdog-${BOT_NAME}-discord.sh - chassis-rendered template.
#
# Monitors the ${TMUX_SESSION_NAME} tmux session for auth failures and
# restarts it via the sibling restart script when needed. Runs every 30
# minutes via the discord-watchdog LaunchAgent, which MUST be a gui-domain
# LaunchAgent (see docs/launchd-domains.md): this script's restart child
# spawns the tmux session that hosts `claude`, and anything launchd starts in
# the Background session cannot reach the user's login keychain.
#
# Generated from chassis/scripts/templates/watchdog-discord.sh.template by
# chassis/scripts/bootstrap-customer-scripts.sh. Do NOT edit the rendered copy.
#
# Template variables (expanded at render time):
#   BOT_NAME            - logical bot name
#   TMUX_SESSION_NAME   - tmux session label
#   CUSTOMER_HOME       - per-customer state root

set -euo pipefail

LOG_DIR="${CUSTOMER_HOME}/logs/scheduled"
LOG_FILE="$LOG_DIR/watchdog.log"
RESTART_SCRIPT="${CUSTOMER_HOME}/scripts/restart-${BOT_NAME}-discord.sh"
# Written by the restart script: "<server-pid> Aqua" for a tmux server it
# created while running in the Aqua (gui) launchd session.
SERVER_STATE_FILE="${CUSTOMER_HOME}/scheduled-tasks/tmux-server-session.state"
mkdir -p "$LOG_DIR"

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }
log() { echo "[$(timestamp)] $*" >> "$LOG_FILE"; }

launchd_session() {
    if command -v launchctl >/dev/null 2>&1; then
        launchctl managername 2>/dev/null || echo "unknown"
    else
        echo "n/a"
    fi
}

tmux_server_pid() {
    tmux display-message -p '#{pid}' 2>/dev/null || true
}

# Defensive: refuse to run if the restart script is missing rather than
# silently retry every 30 min with exit 127 (the Toby case study, #6).
if [[ ! -x "$RESTART_SCRIPT" ]]; then
    log "FATAL: restart script missing at $RESTART_SCRIPT"
    log "  This watchdog cannot recover the session without it."
    log "  Re-render via: bash \$CHASSIS_HOME/chassis/scripts/bootstrap-customer-scripts.sh"
    exit 2
fi

# Check if session exists
if ! tmux has-session -t "${TMUX_SESSION_NAME}" 2>/dev/null; then
    log "Session missing - restarting"
    bash "$RESTART_SCRIPT"
    exit 0
fi

# Poisoned-tmux-server detection (the chassis#14 regression).
#
# A session can look perfectly healthy while sitting on a tmux server that was
# created from a Background launchd session (an old LaunchDaemon). Every claude
# process on that server is keychain-blind, so Vaultwarden-sourced credentials
# fail while the pane shows nothing wrong. The reference install ran five weeks
# in exactly this state. The restart script owns the recovery (it kills the
# SERVER, not just the session); the watchdog only has to notice and delegate.
#
# Only act when WE are under Aqua. A Background-domain run of this watchdog must
# not trigger a server teardown - it would just recreate the poisoned server and
# fight the real agent every 30 minutes.
SESSION_MGR="$(launchd_session)"
if [[ "$SESSION_MGR" == "Aqua" ]]; then
    SERVER_PID="$(tmux_server_pid)"
    RECORDED="$(cat "$SERVER_STATE_FILE" 2>/dev/null || true)"
    if [[ -n "$SERVER_PID" && "$RECORDED" != "${SERVER_PID} Aqua" ]]; then
        log "tmux server ${SERVER_PID} has no Aqua provenance record - session is alive but keychain-blind; delegating to restart (which rebuilds the server)"
        bash "$RESTART_SCRIPT"
        exit 0
    fi
elif [[ "$SESSION_MGR" != "n/a" ]]; then
    log "WARN: watchdog running in launchd session '${SESSION_MGR}', not Aqua - it must be a gui-domain LaunchAgent (see docs/launchd-domains.md)"
fi

# Capture recent pane output for state inspection.
PANE_OUTPUT=$(tmux capture-pane -t "${TMUX_SESSION_NAME}" -p -S -50 2>/dev/null)

if echo "$PANE_OUTPUT" | grep -qiE "Not logged in|Please run /login|authentication.*failed|token.*expired"; then
    log "Auth failure detected - restarting"
    bash "$RESTART_SCRIPT"
    exit 0
fi

# Folder-trust prompt detection (chassis#21). Claude Code's per-directory
# trust gate runs before --dangerously-skip-permissions can apply, so a
# claude process launched into an untrusted directory parks on this prompt
# forever - tmux session looks alive, bot is dead. Bootstrap pre-seed
# (chassis#22) makes this unreachable on new installs; the restart
# template also calls preseed-claude-trust.sh on every restart (chassis#23
# follow-up) so this detection rule has a real recovery path - the restart
# now re-seeds trust before re-launching claude, breaking the previous
# infinite restart loop on trust-wipe.
#
# Regex matches the actual current Claude Code wording: "Quick safety
# check: Is this a project you created or one you trust?" The earlier
# tighter regex matched neither alternative on the real prompt and was
# only saved by the generic-menu fallback below (chassis#23 review by Toby).
if echo "$PANE_OUTPUT" | grep -qiE "Quick safety check|trust this folder|Is this a project you"; then
    log "Folder-trust prompt detected - restarting (restart will re-seed trust via preseed-claude-trust.sh)"
    bash "$RESTART_SCRIPT"
    exit 0
fi

# Generic interactive-prompt detection. Any TUI menu pattern ("> 1." style
# selectable list) in the pane means the process is parked waiting for input
# nothing will provide. Conservative regex: requires a current-selection
# arrow at the start of a line followed by a numbered option, which Claude's
# prompts produce and steady-state log output does not.
if echo "$PANE_OUTPUT" | grep -qE '^[[:space:]]*[>❯][[:space:]]+[0-9]+\.'; then
    log "Interactive prompt detected (unknown menu) - restarting"
    bash "$RESTART_SCRIPT"
    exit 0
fi

log "Session healthy"
